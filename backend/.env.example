GOOGLE_API_KEY=your-key-here

# ── Alpaca Broker API (sandbox) ───────────────────────────────────────────────
# Broker API keys from the Alpaca Broker dashboard (sandbox). Used for the
# per-user brokerage account + invest flow. Paper/sandbox only — never real money.
BROKER_API_KEY=your-broker-key-here
BROKER_SECRET_KEY=your-broker-secret-here

# Broker backend: "alpaca_broker" places real sandbox orders; "simulator"
# (default if unset) keeps everything in-process for offline/local runs.
BROKER_PROVIDER=alpaca_broker

# Firm sweep account UUID for instant JNLC funding. Alpaca does NOT expose this
# via the API — copy it from the Broker dashboard's Accounts view. Required for
# the "Add funds" (journal) step; leave blank to disable instant funding.
BROKER_FIRM_ACCOUNT_ID=
